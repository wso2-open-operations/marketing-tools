# --- Database (Postgres) ---
# Shared with the agenda-organizer Go service — same DB, same marketingops schema.
DB_HOST=localhost
DB_PORT=5432
DB_USER=<db-user>
# Leave blank for local trust-auth setups (e.g. default Postgres.app on macOS).
DB_PASSWORD=<db-password>
DB_NAME=<db-name>
DB_SCHEMA=marketingops
# Use "require" (or stricter) outside local development.
DB_SSLMODE=disable

# --- App server ---
PORT=8080
LOG_LEVEL=info
APP_ENV=development
# Base64-encoded 32-byte key used to encrypt PII at rest. Generate one with:
#   openssl rand -base64 32
PII_ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# --- Auth (x-jwt-assertion) ---
# Set to true in production to enable JWT signature verification via JWKS.
# When false (local dev), the x-jwt-assertion token is decoded without signature verification.
TOKEN_VALIDATOR_ENABLED=false
JWKS_ENDPOINT=<https://<your-idp-host>/oauth2/jwks>
JWT_ISSUER=<https://<your-idp-host>/oauth2/token>
# Only required when TOKEN_VALIDATOR_ENABLED=true.
JWT_AUDIENCE=<expected-jwt-audience>
# Comma-separated list of role names allowed admin access.
RBAC_ADMIN_ROLES=<comma-separated-admin-role-names>

# --- WSO2 Coin / O2C feature flags ---
EXCLUDE_EMPLOYEE_COIN_ALLOCATION=true
ENABLE_QR_VALIDATIONS=true
SESSION_END_TIME_OFFSET_MINUTES=15
# Minutes represented by one slot_index unit in marketingops.sessions. No
# authoritative constant exists in the schema; 5 matches all current data.
SESSION_SLOT_MINUTES=5

# FALLBACK venue timezone. The source of truth is now the real
# conference_config.timezone column (added upstream); the API reads it
# per-event to anchor session instants and to fill the `timezone` payload
# field. VENUE_TIMEZONE is used only when a config row's timezone column is
# empty (it is NOT NULL upstream, so this is a defensive default). Defaults to
# UTC if unset.
VENUE_TIMEZONE=Asia/Colombo

# --- External service integrations ---
# Each service authenticates via its own OAuth2 client-credentials grant.
# The QR scan flow (POST /qr/scan) cannot resolve real QR codes/wallets until
# these are filled in with real values from your environment.

# QR Portal — resolves a scanned QR code's metadata (event type, coin value, etc.)
QR_PORTAL_ENDPOINT=<https://<qr-portal-host>/qr-portal-backend/v1.0>
QR_PORTAL_TOKEN_URL=<https://<idp-host>/oauth2/token>
QR_PORTAL_CLIENT_ID=<qr-portal-oauth2-client-id>
QR_PORTAL_CLIENT_SECRET=<qr-portal-oauth2-client-secret>

# Wallet — resolves a user's primary wallet address
WALLET_ENDPOINT=<https://<wallet-service-host>/wallet-service/v1.0>
WALLET_TOKEN_URL=<https://<idp-host>/oauth2/token>
WALLET_CLIENT_ID=<wallet-oauth2-client-id>
WALLET_CLIENT_SECRET=<wallet-oauth2-client-secret>

# Transaction/Blockchain — executes token transfers (built but currently
# unwired from the scan flow; see internal/service/coin_service.go)
TRANSACTION_ENDPOINT=<https://<transaction-service-host>/transaction-service/v1.0>
TRANSACTION_TOKEN_URL=<https://<idp-host>/oauth2/token>
TRANSACTION_CLIENT_ID=<transaction-oauth2-client-id>
TRANSACTION_CLIENT_SECRET=<transaction-oauth2-client-secret>

# --- AI Features ---
# Unlike the services above, these authenticate by forwarding the caller's
# own x-jwt-assertion verbatim -- no OAuth2 client credentials of their own.
AI_MATCHMAKING_SERVICE_URL=<https://<matchmaking-service-host>>
AI_PERSONALIZE_AGENT_SERVICE_URL=<https://<personalize-agent-service-host>>
AI_PICKED_FOR_YOU_SERVICE_URL=<https://<picked-for-you-service-host>>
AI_CHAT_SERVICE_URL=<https://<chat-service-host>>
AI_REQUEST_TIMEOUT_SECONDS=120
# Each defaults to false ("everything disabled") if unset.
AI_ENABLED_CHAT_ASSISTANT=false
AI_ENABLED_PERSONALIZED_AGENDA=false
AI_ENABLED_MATCH_MAKER=false
AI_ENABLED_O2_BAR=false
